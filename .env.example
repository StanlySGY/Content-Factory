# --- Database (系统 PostgreSQL 16 @ localhost:5432) ---
# 应用运行时：最小权限角色 cf_app，TCP scram，RLS 对其生效（非属主）
DATABASE_URL=postgres://cf_app:cf_app_dev_pw@localhost:5432/content_factory
# 迁移专用：以 sgy（库属主）经 Unix socket peer 认证，无需密码/superuser
DATABASE_ADMIN_URL=postgresql://sgy@/content_factory?host=/var/run/postgresql
# 测试库
DATABASE_URL_TEST=postgres://cf_app:cf_app_dev_pw@localhost:5432/content_factory_test
DATABASE_ADMIN_URL_TEST=postgresql://sgy@/content_factory_test?host=/var/run/postgresql
# 审计只读身份（写读分离 ADR-008；审计查询走此连接）
DATABASE_AUDIT_URL=postgres://cf_audit_reader:cf_audit_dev_pw@localhost:5432/content_factory
DATABASE_AUDIT_URL_TEST=postgres://cf_audit_reader:cf_audit_dev_pw@localhost:5432/content_factory_test

# --- API ---
APP_PORT=3001
WEB_ORIGIN=http://localhost:5173

# 说明：以上为本地开发占位值。真实凭证严禁入仓（setup.md §4.2），
# 经环境变量或本地 vault 注入；复制本文件为 .env 使用。
# 数据库供给见 db/provision.sql（需 superuser 执行一次）。

# --- Production launch readiness（默认请保持关闭；仅目标环境逐项启用） ---
# 只允许选择一个真实启用路线：agent / mcp / publisher / writeback。
# EXECUTION_PRODUCTION_ENABLEMENT_SCOPE=agent
# EXECUTION_RUNTIME_MODE=real_enabled
# EXECUTION_RUNTIME_ADAPTER_MODE=real
# EXECUTION_ALLOW_REAL_RUNTIME=true
# EXECUTION_ALLOW_NETWORK=true
# EXECUTION_NETWORK_ALLOWLIST=api.openai.test
# AGENT_OPENAI_COMPATIBLE_ENDPOINT=https://api.openai.test/v1/chat/completions

# 外部 secret registry contract：key ref -> env material source。真实密钥仍只由环境/Vault 注入，不入仓。
# EXECUTION_SECRET_STORE_ENABLED=true
# EXECUTION_SECRET_INJECTION_ENABLED=true
# EXECUTION_SECRET_STORE_KIND=external_registry
# EXECUTION_EXTERNAL_SECRET_REGISTRY=secret://llm/openai=env://CONTENT_FACTORY_OPENAI_KEY
# EXECUTION_SECRET_ROTATION_POLICY_ENABLED=true

# 额度与成本硬限制。
# EXECUTION_PROVIDER_DAILY_REQUEST_LIMIT=10
# EXECUTION_PROVIDER_DAILY_COST_LIMIT_CENTS=100
# EXECUTION_PROVIDER_ESTIMATED_COST_PER_REQUEST_CENTS=1

# 运维闭环与低权限 staging smoke。
# EXECUTION_MONITORING_ENABLED=true
# EXECUTION_ALERTING_PROVIDER=pagerduty
# EXECUTION_STAGING_SMOKE_ENABLED=true
# EXECUTION_STAGING_SMOKE_RUNTIME_MODE=real_low_privilege
# EXECUTION_STAGING_SMOKE_CREDENTIAL_REF=secret://llm/openai
# EXECUTION_AGENT_PROVIDER_STAGING_ENABLED=true
