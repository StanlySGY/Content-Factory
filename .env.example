# --- Database (系统 PostgreSQL 16 @ localhost:5432) ---
# 应用运行时：最小权限角色 cf_app，TCP scram，RLS 对其生效（非属主）
DATABASE_URL=postgres://cf_app:cf_app_dev_pw@localhost:5432/content_factory
# 迁移专用：以 sgy（库属主）经 Unix socket peer 认证，无需密码/superuser
DATABASE_ADMIN_URL=postgresql://sgy@/content_factory?host=/var/run/postgresql
# 测试库
DATABASE_URL_TEST=postgres://cf_app:cf_app_dev_pw@localhost:5432/content_factory_test
DATABASE_ADMIN_URL_TEST=postgresql://sgy@/content_factory_test?host=/var/run/postgresql
# 审计只读身份（写读分离 ADR-008；审计查询走此连接）
DATABASE_AUDIT_URL=postgres://cf_audit_reader:cf_audit_dev_pw@localhost:5432/content_factory
DATABASE_AUDIT_URL_TEST=postgres://cf_audit_reader:cf_audit_dev_pw@localhost:5432/content_factory_test

# --- API ---
APP_PORT=3001
WEB_ORIGIN=http://localhost:5173

# 说明：以上为本地开发占位值。真实凭证严禁入仓（setup.md §4.2），
# 经环境变量或本地 vault 注入；复制本文件为 .env 使用。
# 数据库供给见 db/provision.sql（需 superuser 执行一次）。
